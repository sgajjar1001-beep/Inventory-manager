rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Allow reading user credentials to verify password login
      allow read: if true;
      // Allow creating, registering, updating user settings
      allow create: if incoming().id == userId;
      allow update: if incoming().id == userId;
      allow delete: if false;
    }

    // --- Materials Collection ---
    match /materials/{materialId} {
      allow read: if true;
      allow create: if true; // Allow creating new items
      allow update: if true;
      allow delete: if true;
    }

    // --- GRN Collection ---
    match /grn/{grnId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
  }
}
